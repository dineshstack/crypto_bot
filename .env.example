# ═══════════════════════════════════════════════════════════════════════════
# Claude-Powered BTC+ETH Trading Bot — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this to .env and fill in your keys:
#   cp .env.example .env && nano .env

# ── Required ──────────────────────────────────────────────────────────────

# Claude API — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Binance — SPOT API KEY ONLY, NO WITHDRAWAL PERMISSION
# Create at binance.com → API Management → Enable Spot only
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret

# Telegram — token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# MySQL — local database on VPS (create: mysql -u root -p < mysql_schema.sql)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=crypto_bot
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=crypto_bot

# API key for dashboard → VPS communication (generate: openssl rand -hex 32)
API_SECRET_KEY=your_random_api_key_here

# ── Optional (improve analysis quality) ───────────────────────────────────

# CoinGecko — higher rate limits for /newcoins and /research
# Get a free demo key at https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# NewsAPI — better news coverage (100 req/day free tier)
# Get a free key at https://newsapi.org
# Leave empty to use free RSS feeds (CoinDesk, CoinTelegraph, Reuters, Kitco)
NEWS_API_KEY=

# LunarCrush — social sentiment (requires Individual plan $5/day for API)
# Free Hobby tier has NO API access — leave empty to use Reddit RSS fallback
LUNARCRUSH_API_KEY=

# ── Safety ────────────────────────────────────────────────────────────────

# TESTNET=true → uses Binance testnet, no real money
# TESTNET=false → LIVE trading, every buy/sell needs your Telegram approval
TESTNET=true
